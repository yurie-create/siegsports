<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>運営者情報｜SiegSports</title>

  <meta name="description" content="SiegSportsの運営者情報ページです。社会人陸上チームとしての活動やサイト運営方針について掲載しています。">

  <style>
    body {
      margin: 0;
      background: white;
      color: #0f0f0f;
      font-family: "Helvetica Neue", sans-serif;
    }

    .about-page {
      max-width: 800px;
      margin: 0 auto;
      padding: 80px 20px;
      line-height: 2;
    }

    .about-page h1 {
      font-size: 42px;
      margin-bottom: 50px;
      text-align: center;
      letter-spacing: 2px;
    }

    .about-page p {
      font-size: 16px;
      margin-bottom: 28px;
      color:#0f0f0f;
    }

    .contact-link {
      color: #4da3ff;
      text-decoration: none;
    }

    .contact-link:hover {
      text-decoration: underline;
    }

    @media screen and (max-width: 768px) {
      .about-page {
        padding: 60px 20px;
      }

      .about-page h1 {
        font-size: 30px;
        margin-bottom: 40px;
